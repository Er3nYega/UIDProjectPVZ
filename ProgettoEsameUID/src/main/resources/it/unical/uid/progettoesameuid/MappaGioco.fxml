                                <Button mnemonicParsing="false" onAction="#ritornaAlMenuGameOver" prefHeight="60.0" prefWidth="400.0" minWidth="400.0" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 22px; -fx-background-radius: 15; -fx-cursor: hand;" text="TORNA AL MENU PRINCIPALE">
