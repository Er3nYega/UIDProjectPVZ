                        <VBox fx:id="menuPausa" alignment="CENTER" fillWidth="false" maxHeight="520.0" maxWidth="450.0" prefHeight="520.0" prefWidth="450.0" spacing="10.0" style="-fx-padding: 60px 35px 35px 35px;" visible="false" AnchorPane.leftAnchor="735.0" AnchorPane.topAnchor="280.0">
