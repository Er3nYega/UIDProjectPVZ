                                <Button mnemonicParsing="false" onAction="#chiudiSettingsPausa" prefHeight="35.0" prefWidth="110.0" styleClass="bottone-indietro" text="INDIETRO">
                                    <VBox.margin>
                                        <Insets top="5.0" />
                                    </VBox.margin>
                                </Button>
                            </children>
                        </VBox>

                        <!-- SCHERMATA DI GAME OVER -->
